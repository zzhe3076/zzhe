.container {
  padding: 20px;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40px 0;
}

.title {
  display: block;
  font-size: 28px;
  font-weight: bold;
  color: #333;
}

.form {
  background: #fff;
  border-radius: 12px;
  padding: 30px;
}

.form-group {
  margin-bottom: 20px;
}

.label {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}

.input {
  width: 100%;
  height: 44px;
  padding: 0 15px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background: linear-gradient(135deg, #0066cc, #00a0e9);
  color: #fff;
  border-radius: 8px;
  font-size: 16px;
  border: none;
  margin-top: 20px;
}

.btn-primary::after {
  border: none;
}

.btn-wechat {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background: #07c160;
  color: #fff;
  border-radius: 8px;
  font-size: 16px;
  margin-top: 15px;
  border: none;
}

.btn-wechat::after {
  border: none;
}

.register-link {
  text-align: center;
  margin-top: 20px;
  font-size: 14px;
  color: #666;
}
