.container {
  padding: 20px;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.item {
  background: #fff;
  border-radius: 12px;
  padding: 15px;
}

.item-question {
  font-size: 14px;
  color: #333;
  font-weight: bold;
  margin-bottom: 8px;
}

.item-answer {
  font-size: 13px;
  color: #666;
  line-height: 1.6;
}

.empty {
  text-align: center;
  padding: 40px;
  color: #999;
  font-size: 14px;
}
