.container {
  padding: 20px;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.item {
  background: #fff;
  border-radius: 12px;
  padding: 15px;
}

.item-title {
  font-size: 14px;
  color: #333;
  margin-bottom: 5px;
}

.item-date {
  font-size: 12px;
  color: #999;
}

.empty {
  text-align: center;
  padding: 40px;
  color: #999;
  font-size: 14px;
}
