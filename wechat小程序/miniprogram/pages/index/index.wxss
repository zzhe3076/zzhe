.container {
  padding: 20px;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40px 0;
}

.title {
  display: block;
  font-size: 28px;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 14px;
  color: #999;
  margin-top: 10px;
}

.stats {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 24px;
  font-weight: bold;
  color: #0066cc;
}

.stat-label {
  display: block;
  font-size: 12px;
  color: #999;
  margin-top: 5px;
}

.section {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.section-title text {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.more {
  font-size: 12px;
  color: #0066cc;
}

.announcement-list, .faq-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.announcement-item, .faq-item {
  padding: 15px;
  background: #f9f9f9;
  border-radius: 8px;
}

.announcement-title, .faq-question {
  font-size: 14px;
  color: #333;
  margin-bottom: 5px;
}

.announcement-date, .faq-answer {
  font-size: 12px;
  color: #999;
}

.empty {
  text-align: center;
  padding: 40px;
  color: #999;
  font-size: 14px;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 20px;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border: none;
  padding: 15px;
  border-radius: 12px;
}

.action-btn::after {
  border: none;
}

.action-icon {
  width: 40px;
  height: 40px;
  margin-bottom: 8px;
}

.action-btn text {
  font-size: 12px;
  color: #666;
}
